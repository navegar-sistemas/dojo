[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/presentation/tower_complete_screen.gd" id="1_complete"]

[node name="TowerComplete" type="PanelContainer"]
script = ExtResource("1_complete")
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 24

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "SYSTEM RESTORED"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 48
theme_override_colors/font_color = Color(0, 1, 0.4, 1)

[node name="ExitCode" type="Label" parent="VBox"]
layout_mode = 2
text = "exit 0"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0, 1, 0.4, 1)

[node name="Subtitle" type="Label" parent="VBox"]
layout_mode = 2
text = "Você completou todos os 9 níveis da beginner tower."
horizontal_alignment = 1
autowrap_mode = 3
theme_override_font_sizes/font_size = 18

[node name="Credits" type="Label" parent="VBox"]
layout_mode = 2
text = "42 Warrior — Game Jam 42SP\nInspired by Ruby Warrior (Ryan Bates)\nBuilt with Godot 4 + GDScript\nArte e áudio originais"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.7, 0.7, 0.7, 1)

[node name="MenuBtn" type="Button" parent="VBox"]
layout_mode = 2
text = "⌂ Menu Principal"
theme_override_font_sizes/font_size = 20
