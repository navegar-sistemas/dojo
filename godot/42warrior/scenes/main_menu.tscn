[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://src/presentation/main_menu.gd" id="1_menu"]
[ext_resource type="Script" path="res://src/presentation/four_state_button.gd" id="2_fsbutton"]
[ext_resource type="Texture2D" path="res://assets/v1/key_art.png" id="3_keyart"]

[node name="MainMenu" type="PanelContainer"]
script = ExtResource("1_menu")
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VoidBackground" type="ColorRect" parent="."]
layout_mode = 2
color = Color(0.039, 0.039, 0.043, 1)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 12

[node name="BootLog" type="Label" parent="VBox"]
layout_mode = 2
text = "$ ./42warrior --boot
[WARN] corruption detected"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.4, 0.9, 0.5, 1)

[node name="KeyArt" type="TextureRect" parent="VBox"]
layout_mode = 2
texture = ExtResource("3_keyart")
expand_mode = 1
stretch_mode = 5
custom_minimum_size = Vector2(0, 120)

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "42 WARRIOR"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32
theme_override_colors/font_color = Color(0, 0.941, 1, 1)

[node name="StartBtn" type="Button" parent="VBox"]
script = ExtResource("2_fsbutton")
layout_mode = 2
size_flags_horizontal = 4
text = "▶ Jogar"
