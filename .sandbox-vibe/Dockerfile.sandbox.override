# Override layer generated by sandbox-vibe.
# Edit only with full understanding — this file may be regenerated by 'sandbox-vibe init'.

FROM sandbox-vibe-base:latest

USER root

# Always: npm + Claude Code
RUN npm install -g npm@latest \
 && npm install -g @anthropic-ai/claude-code@latest

# --- Projeto 42 (libft): toolchain C + man pages + norminette ---

# node:24-slim (Debian) descarta as man pages via dpkg excludes; removemos o
# filtro ANTES de instalar para que `man 3 strlen`, `man 3 strncmp` etc.
# fiquem disponiveis no container (o projeto estuda as man da libc).
RUN rm -f /etc/dpkg/dpkg.cfg.d/docker

# build-essential -> gcc, make, libc6-dev. libbsd-dev -> strnstr de referencia
# nos testes (ausente na glibc). gdb/valgrind -> debug e memcheck.
# python3-venv -> isolar a norminette. man* -> man pages secao 3 da libc.
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential \
      libbsd-dev \
      gdb \
      valgrind \
      python3-venv \
      man-db \
      manpages \
      manpages-dev \
    && rm -rf /var/lib/apt/lists/*

# norminette (linter da norma 42) em venv isolado, exposto no PATH.
RUN python3 -m venv /opt/norminette \
    && /opt/norminette/bin/pip install --no-cache-dir norminette==3.3.59 \
    && ln -s /opt/norminette/bin/norminette /usr/local/bin/norminette

USER sandbox
